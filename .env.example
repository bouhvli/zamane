# Neon Postgres connection string (unpooled — the serverless HTTP driver doesn't need PgBouncer)
DATABASE_URL="postgres://user:password@ep-example-123456.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Resend API key for password-reset emails. Leave empty to fall back to
# logging the reset link to the server console and returning it in the API
# response (dev only, never in production).
RESEND_API_KEY=

# Base URL used to build links in emails (password reset, etc).
APP_URL=http://localhost:3000

NODE_ENV=development
